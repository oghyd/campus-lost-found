<!--
    themes.xml (night) — dark-mode override for the app theme.
    Applied automatically by the system when the device is in dark mode.
    Inherits from the same base theme; individual colour overrides can be added here.
-->
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CampusLostFound" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary_variant</item>
    </style>
</resources>