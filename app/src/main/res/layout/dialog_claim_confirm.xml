<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_claim_confirm.xml — custom dialog body for the "Mark as Claimed" confirmation.

    Note: ItemDetailActivity currently uses an AlertDialog.Builder inline rather than
    inflating this layout. This file is kept for a future custom dialog implementation.

    Ownership: Mona.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Marquer comme Claimed ?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#212121"/>

    <TextView
        android:id="@+id/tv_dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Quelqu'un a trouvé cet objet. Le propriétaire sera notifié."
        android:textColor="#757575"/>

</LinearLayout>