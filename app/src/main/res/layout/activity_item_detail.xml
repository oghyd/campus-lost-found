<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_item_detail.xml — detail screen for a single lost/found item.

    Structure:
    - Toolbar at the top (primary colour, back arrow).
    - fragment_container FrameLayout (weight=1) — ItemDetailFragment is committed here.
    - Bottom panel (white card, elevation 8dp) with two action buttons:
        - btn_claim          — "Mark as Claimed" (hidden by default, shown to non-owners).
        - btn_confirm_returned — "Confirm Returned" (hidden by default, shown to owner when CLAIMED).

    Ownership: Mona (fragment); Omar (status buttons).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"/>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_claim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mark as Claimed"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_returned"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm Returned"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>

</LinearLayout>