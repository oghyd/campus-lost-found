<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_post_item.xml — form for creating or editing a lost/found report.

    Fields (all inside a scrollable LinearLayout):
    - et_title        TextInputEditText — item title (required).
    - et_description  TextInputEditText — multi-line description (required).
    - et_location     TextInputEditText — where the item was lost/found (required).
    - spinner_category Spinner — category selection (Electronics, Documents, …).
    - toggle_type      MaterialButtonToggleGroup — LOST / FOUND (required).
    - btn_date         MaterialButton — opens a DatePickerDialog (required).
    - iv_photo_preview ImageView — preview of attached photo (hidden until photo selected).
    - btn_attach_photo MaterialButton — triggers camera intent (optional).
    - btn_submit       MaterialButton — validates form and saves to Realm.

    Ownership: Ines (camera/photo section); rest shared.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITLE -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Item Title *"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- DESCRIPTION -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description *"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:maxLines="6"
                android:gravity="top" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- LOCATION -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Location *"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- CATEGORY LABEL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category *"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp" />

        <!-- CATEGORY SPINNER -->
        <Spinner
            android:id="@+id/spinner_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/btn_dropdown"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- LOST / FOUND TOGGLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type *"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_lost"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOST" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_found"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FOUND" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- DATE PICKER BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_date"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Date *"
            android:layout_marginBottom="12dp"
            app:icon="@android:drawable/ic_menu_my_calendar" />

        <!-- PHOTO SECTION (Phase 4 - Bonus 1) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Photo (optional)"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp" />

        <ImageView
            android:id="@+id/iv_photo_preview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:contentDescription="Photo preview"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_attach_photo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attach Photo"
            android:layout_marginBottom="24dp"
            app:icon="@android:drawable/ic_menu_camera" />

        <!-- SUBMIT BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Post Item"
            android:textSize="16sp"
            android:padding="14dp" />

    </LinearLayout>
</ScrollView>
