<?xml version="1.0" encoding="utf-8"?>
<!--
    colors.xml — global colour palette for Campus Lost & Found.

    Sections:
    - Material baseline colours (purple/teal) — kept from project scaffold, rarely used directly.
    - Brand colours: primary (navy #1E3A8A) and secondary (green #10B981).
    - Status chip colours: open (dark green), claimed (amber), returned (grey), unknown (light grey).

    All colours referenced as @color/<name> in layouts and as R.color.<name> in Java.
    Ownership: Omar seeds status colours; all team may add entries via PR.
-->
<resources>
    <color name="purple_200">#BB86FC</color>
    <color name="purple_500">#6200EE</color>
    <color name="purple_700">#3700B3</color>
    <color name="teal_200">#03DAC5</color>
    <color name="teal_700">#018786</color>
    <color name="black">#000000</color>
    <color name="white">#FFFFFF</color>

    <color name="primary">#1E3A8A</color>
    <color name="primary_variant">#1D4ED8</color>
    <color name="secondary">#10B981</color>

    <color name="status_open">#2E7D32</color>
    <color name="status_claimed">#F9A825</color>
    <color name="status_returned">#757575</color>
    <color name="status_unknown">#9E9E9E</color>
</resources>